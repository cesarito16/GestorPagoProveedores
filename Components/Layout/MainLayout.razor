@inherits LayoutComponentBase

<MudThemeProvider Theme="_currentTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="background-color: #594ae2; color: white;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@DrawerToggle" />
        <MudText Typo="Typo.h6" Class="ml-3">MiAppMudHybrid</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Anchor="Anchor.Start"
               Variant="DrawerVariant.Persistent"
               ClipMode="DrawerClipMode.Always"
               Elevation="1">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="background-color: #fcfcfc; min-height: 100vh; padding: 88px 24px 24px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    // Controla si el menú está expandido o colapsado
    bool _drawerOpen = true;

    // Configuración de la paleta para MudBlazor v7+ (Modo Claro de tu captura)
    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#594ae2",
            AppbarBackground = "#594ae2",
            Background = "#fcfcfc",
            Surface = "#ffffff"
        }
    };

    // Función que activa y desactiva el menú lateral al hacer clic
    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}